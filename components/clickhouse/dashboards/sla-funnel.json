          "format": "table",
          "query": "WITH final AS (\n  SELECT\n    run_id,\n    upper(trim(argMax(status, event_time))) AS final_status\n  FROM reports.report_runs_v\n  WHERE requested_at >= now() - INTERVAL 6 HOUR\n    AND requested_at <  now()\n  GROUP BY run_id\n)\nSELECT\n  final_status AS status,\n  count() AS runs\nFROM final\nGROUP BY final_status\nORDER BY runs DESC",
          "refId": "A"
        }
