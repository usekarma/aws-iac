        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "adHocFilters": [],
          "adHocValuesQuery": "",
          "add_metadata": true,
          "contextWindowSize": "10",
          "editorMode": "builder",
          "extrapolate": true,
          "format": "table",
          "formattedQuery": "/* grafana dashboard='SLA Funnel & Dead Ends (Stage Flow)', user=0 */\nWITH per_run AS (\n  SELECT\n    run_id,\n    upper(trim(argMax(status, event_time))) AS final_status,\n    argMax(latency_ms, event_time)          AS latency_ms\n  FROM reports.report_runs_v\n  WHERE requested_at >= now() - INTERVAL 6 HOUR\n    AND requested_at <  now()\n  GROUP BY run_id\n)\nSELECT\n  avg(\n    if(\n      final_status = 'FAILED'\n      OR (final_status = 'SUCCESS' AND latency_ms > 30000),\n      1, 0\n    )\n  ) AS value\nFROM per_run",
          "interval": "",
          "intervalFactor": 1,
          "nullifySparse": false,
          "query": "WITH per_run AS (\n  SELECT\n    run_id,\n    upper(trim(argMax(status, event_time))) AS final_status,\n    argMax(latency_ms, event_time)          AS latency_ms\n  FROM reports.report_runs_v\n  WHERE requested_at >= now() - INTERVAL 6 HOUR\n    AND requested_at <  now()\n  GROUP BY run_id\n)\nSELECT\n  avg(\n    if(\n      final_status = 'FAILED'\n      OR (final_status = 'SUCCESS' AND latency_ms > 30000),\n      1, 0\n    )\n  ) AS value\nFROM per_run\n",
          "refId": "A",
          "round": "0s",
          "skip_comments": true,
          "useWindowFuncForMacros": true
        }
      ],
      "title": "SLA Breach Rate (last 6h)",
      "type": "stat"
    },
