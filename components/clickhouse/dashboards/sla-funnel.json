      "targets": [
        {
          "format": "table",
          "query": "WITH events AS (\n  SELECT\n    run_id,\n    event_time,\n    upper(trim(status)) AS stage\n  FROM reports.report_runs_v\n  WHERE requested_at >= now() - INTERVAL 6 HOUR\n    AND requested_at <  now()\n), ordered AS (\n  SELECT\n    run_id,\n    stage,\n    lagInFrame(stage) OVER (PARTITION BY run_id ORDER BY event_time) AS prev_stage\n  FROM events\n)\nSELECT\n  prev_stage AS source_stage,\n  stage      AS target_stage,\n  count()    AS transitions\nFROM ordered\nWHERE prev_stage IS NOT NULL\n  AND prev_stage != ''\n  AND stage != prev_stage\nGROUP BY source_stage, target_stage\nORDER BY transitions DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Stage Transitions (Top 50 edges, last 6h)",
      "type": "table"
    },
