      "pluginVersion": "12.3.1",
      "targets": [
        {
          "format": "time_series",
          "query": "WITH per_run AS (\n  SELECT\n    run_id,\n    min(requested_at) AS req_at,\n    upper(trim(argMax(status, event_time))) AS final_status\n  FROM reports.report_runs_v\n  WHERE requested_at >= now() - INTERVAL 6 HOUR\n    AND requested_at <  now()\n  GROUP BY run_id\n)\nSELECT\n  toStartOfInterval(req_at, INTERVAL 5 MINUTE) AS time,\n  count() AS requested,\n  countIf(final_status = 'SUCCESS') AS success,\n  countIf(final_status = 'FAILED')  AS failed,\n  countIf(final_status NOT IN ('SUCCESS','FAILED')) AS other\nFROM per_run\nGROUP BY time\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Runs by Final Outcome (last 6h, 5m buckets)",
      "type": "timeseries"
    },
